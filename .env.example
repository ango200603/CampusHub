# CampusHub local environment template.
# Copy this file to .env for local scripts, or configure the same variables in your IDE/run environment.

# Application
APP_ENV=local
TZ=Asia/Shanghai
NEXT_PUBLIC_API_BASE=http://localhost:8080

# Docker build images
MAVEN_IMAGE=public.ecr.aws/docker/library/maven:3.9.9-eclipse-temurin-21
RUNTIME_IMAGE=public.ecr.aws/docker/library/eclipse-temurin:21-jre
NODE_IMAGE=public.ecr.aws/docker/library/node:22-alpine

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_HOST_PORT=3307
MYSQL_DATABASE=campus_hub
MYSQL_USER=root
MYSQL_PASSWORD=root

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD is not wired in the current application.yml files. Add it there before enabling Redis auth.
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_MANAGEMENT_PORT=15672

# Nacos
NACOS_ADDR=localhost:8848
NACOS_NAMESPACE=
NACOS_GROUP=DEFAULT_GROUP
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos

# MinIO
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=campus-files
MINIO_CONSOLE_PORT=9001

# JWT
# Replace in every non-local environment. HS256 secrets should be high-entropy and at least 32 bytes.
JWT_SECRET=CampusHubSecretKeyForJwtHS256NeedsAtLeast32Bytes2026
JWT_EXPIRE_SECONDS=604800

# Sentinel
SENTINEL_DASHBOARD=localhost:8858
SENTINEL_TRANSPORT_PORT=8719

# Service ports
GATEWAY_PORT=8080
AUTH_SERVICE_PORT=8101
USER_SERVICE_PORT=8102
FILE_SERVICE_PORT=8103
AI_SERVICE_PORT=8104
TRADE_SERVICE_PORT=8105
ORDER_SERVICE_PORT=8106
PAY_SERVICE_PORT=8107
NOTICE_SERVICE_PORT=8108
ADMIN_SERVICE_PORT=8109
